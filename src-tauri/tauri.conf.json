{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eversoul-ai-chat",
  "version": "0.0.10",
  "identifier": "com.eversoul.ai.chat",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EverSoul AI Chat",
        "width": 1440,
        "height": 900,
        "minWidth": 1320,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "GarnetRapture",
    "copyright": "Copyright © 2026 GarnetRapture",
    "shortDescription": "EverSoul AI Chat",
    "homepage": "https://n9k32.com/"
  }
}
